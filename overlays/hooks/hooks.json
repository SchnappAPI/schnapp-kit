{
  "description": "schnapp-overlays branch hygiene hooks: block commits to main, auto-PR on push, auto-merge clean branches, inject git context on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/claude/session-start-git-context.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/claude/no-commit-to-main.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/claude/auto-pr-after-commit.sh\"",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/claude/auto-merge-on-stop.sh\"",
            "asyncRewake": true,
            "rewakeMessage": "Background branch cleanup completed — report the result below to the user, then continue:",
            "rewakeSummary": "Auto-merged feature branch to main"
          }
        ]
      }
    ]
  }
}
